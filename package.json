{
  "name": "@kadi1m/axiomvault-client",
  "version": "1.0.6",
  "description": "Client for AxiomVault log API — hashed, signed, immutable event logging",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.mjs",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js",
      "types": "./dist/cjs/index.d.ts"
    }
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && npm run build:cjs && npm run build:esm && node scripts/rename-esm.js",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "github:kadi1m/AxiomVault-package"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "keywords": [
    "axiomvault",
    "logging",
    "audit",
    "client"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16"
  },
  "files": [
    "dist"
  ]
}
